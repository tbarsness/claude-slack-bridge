<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Template launchd agent for claude-slack-bridge.

  Replace the placeholders before installing:
    {{LABEL}}     - reverse-DNS label, e.g. com.timbarsness.ivy-slack
    {{NODE_BIN}}  - absolute path to node, e.g. /usr/local/bin/node
                    (find with: which node)
    {{REPO_DIR}}  - absolute path to your clone of claude-slack-bridge
    {{LOG_DIR}}   - absolute path for stdout/stderr logs

  Install:
    cp launchd/com.example.claude-slack-bridge.plist \
       ~/Library/LaunchAgents/{{LABEL}}.plist
    launchctl load -w ~/Library/LaunchAgents/{{LABEL}}.plist

  Reload after edits:
    launchctl unload ~/Library/LaunchAgents/{{LABEL}}.plist
    launchctl load   ~/Library/LaunchAgents/{{LABEL}}.plist
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>{{LABEL}}</string>

  <key>ProgramArguments</key>
  <array>
    <string>{{NODE_BIN}}</string>
    <string>--enable-source-maps</string>
    <string>{{REPO_DIR}}/dist/index.js</string>
  </array>

  <key>WorkingDirectory</key>
  <string>{{REPO_DIR}}</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>NODE_ENV</key>
    <string>production</string>
  </dict>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
    <key>Crashed</key>
    <true/>
  </dict>

  <key>ThrottleInterval</key>
  <integer>10</integer>

  <key>StandardOutPath</key>
  <string>{{LOG_DIR}}/launchd.out.log</string>

  <key>StandardErrorPath</key>
  <string>{{LOG_DIR}}/launchd.err.log</string>
</dict>
</plist>
