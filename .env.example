# Slack app credentials (see docs/SETUP.md)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...

# Comma-separated Slack user IDs allowed to drive the bot.
# Anyone else who DMs the bot will be politely refused.
ALLOWED_USER_IDS=U0123456789

# Assistants this bridge serves. Each assistant has a name (used as the slash
# command, e.g. "ivy" -> /ivy) and an absolute working directory. Each Claude
# session inherits that directory's CLAUDE.md, .claude/settings.json, MCP
# servers, and skills. Names must be lowercase alphanumeric.
#
# Format: name:absolute-path,name:absolute-path
ASSISTANTS=ivy:/Users/you/projects/ivy,jude:/Users/you/projects/jude

# Assistant used for DMs and any channel without an explicit mapping below.
DEFAULT_ASSISTANT=ivy

# Optional: pin specific channels to specific assistants. New threads in these
# channels (started via slash command) route to the named assistant; in DMs,
# DEFAULT_ASSISTANT is used unless overridden by /<assistant>.
#
# Format: channelId:assistantName,channelId:assistantName
# CHANNEL_ASSISTANTS=C0123456789:jude,C0987654321:ivy

# Optional: override the system prompt sent on the first turn of every new
# thread, applied to every assistant. If unset, each assistant's CLAUDE.md is
# the only system context.
# CLAUDE_SYSTEM_PROMPT="You are responding from Slack. Keep replies concise."

# Optional: override the model. Applies to every assistant. If unset, the
# SDK default is used.
# CLAUDE_MODEL=claude-sonnet-4-6

# Where to persist the threadKey -> {sessionId, assistant} map.
# Default: ./sessions.json
# SESSIONS_FILE=./sessions.json

# Where to write logs. Default: ./logs
# LOG_DIR=./logs
