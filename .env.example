# Slack app credentials (see docs/SETUP.md)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...

# Comma-separated Slack user IDs allowed to drive the bot.
# Anyone else who DMs the bot will be politely refused.
ALLOWED_USER_IDS=U0123456789

# Working directory the Claude Code session runs in. The session inherits
# this project's CLAUDE.md, .claude/settings.json, MCP servers, and skills.
CLAUDE_WORKING_DIR=/Users/you/projects/your-assistant

# Optional: override the system prompt sent on the first turn of every new thread.
# If unset, the project's CLAUDE.md is the only system context.
# CLAUDE_SYSTEM_PROMPT="You are responding from Slack. Keep replies concise."

# Optional: override the model. If unset, the SDK default is used.
# CLAUDE_MODEL=claude-sonnet-4-6

# Where to persist the thread_ts -> session_id map. Default: ./sessions.json
# SESSIONS_FILE=./sessions.json

# Where to write logs. Default: ./logs
# LOG_DIR=./logs
